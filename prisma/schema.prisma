generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                      @id @default(autoincrement())
  name                    String?
  email                   String
  password                String?
  image                   String?
  role                    Role?
  hourlyRate              Decimal?                 @db.Decimal(10, 2)
  monthlyBaseHours        Int?
  employeeStatus          EmployeeStatus?          @default(ACTIVE)
  joinedAt                DateTime?
  worksOnSaturday         Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  resetOTP                String?
  resetOTPExpiry          DateTime?
  hoursPerWeek            Decimal?                 @default(0) @db.Decimal(5, 2)
  phone                   String?                  @unique
  monthlyRate             Int?
  linkedClientId          String?
  emailNotifications      Boolean                  @default(true)
  slackNotifications      Boolean                  @default(false)
  slackUserId             String?
  accounts                Account[]
  affiliateCommissions    AffiliateCommission[]
  auditLogs               AuditLog[]
  bids                    Bid[]
  bonuses                 Bonus[]
  client                  Client?
  createdContracts        Contract[]               @relation("ContractCreator")
  deductions              Deduction[]
  editorClientPermissions EditorClientPermission[] @relation("EditorPermissions")
  feedbackSent            Feedback[]               @relation("FeedbackSender")
  feedbackResponses       FeedbackResponse[]       @relation("FeedbackResponseSender")
  invoicesCreated         Invoice[]                @relation("InvoiceCreator")
  assignedJobs            Job[]                    @relation("JobAssignee")
  createdJobs             Job[]                    @relation("JobCreator")
  leaves                  Leave[]
  loginAuditLogs          LoginAuditLog[]
  payrolls                Payroll[]
  achievements            QCAchievement[]
  qcAnalytics             QCAnalytics[]
  categoryMetrics         QCCategoryMetrics[]
  monthlyTrends           QCMonthlyTrend[]
  rejectionReasons        QCRejectionReason[]
  salesLeads              SalesLead[]
  salesLeadGenerationJobs SalesLeadGenerationJob[]
  sessions                Session[]
  shootDetails            ShootDetail[]            @relation("VideographerShootDetails")
  updatedSocialLogins     SocialLogin[]            @relation("LoginUpdatedBy")
  assignedTasks           Task[]                   @relation("AssignedTasks")
  clientTasks             Task[]                   @relation("ClientUserTasks")
  qcReviewedTasks         Task[]                   @relation("QCReviewedTasks")
  taskFeedback            TaskFeedback[]           @relation("TaskFeedbackAuthor")
  linkedClient            Client?                  @relation("LinkedClientUsers", fields: [linkedClientId], references: [id])
  securityPin             UserSecurityPin?
  twoFactorAuth           UserTwoFactorAuth?
  eodReports              EditorEodReport[]

  @@index([email])
  @@index([role])
  @@index([employeeStatus])
  @@index([linkedClientId])
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String  @default("pending")
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Task {
  id                   String              @id @default(cuid())
  title                String?
  description          String
  taskType             String?
  status               TaskStatus?         @default(PENDING)
  dueDate              DateTime?
  clientUserId         Int?
  folderType           String?
  assignedTo           Int
  qc_specialist        Int?
  scheduler            Int?
  videographer         Int?
  createdBy            Int?
  clientId             String?
  monthlyDeliverableId String?
  driveFolderId        String?
  attachments          Json?
  driveLinks           String[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  priority             String?
  taskCategory         String?
  nextDestination      String?
  clientReview         Boolean?            @default(false)
  requiresClientReview Boolean?            @default(false)
  workflowStep         String?
  feedback             String?
  qcNotes              String?
  qcResult             String?
  route                String?
  monthFolder          String?
  outputFolderId       String?
  deliverableType      String?
  hasCovers            Boolean             @default(false)
  hasMainFile          Boolean             @default(false)
  hasMusicLicense      Boolean             @default(false)
  hasThumbnails        Boolean             @default(false)
  hasTiles             Boolean             @default(false)
  socialMediaLinks     Json                @default("[]")
  platform             String?
  suggestedTitles      Json?
  titlingError         String?
  titlingStatus        String              @default("NONE")
  transcript           String?
  transcriptSummary    String?
  qcReviewedAt         DateTime?
  qcReviewedBy         Int?
  oneOffDeliverableId  String?
  recurringMonth       String?
  billedAt             DateTime?
  invoiceId            String?
  isTrial              Boolean             @default(false)
  isExtra              Boolean             @default(false)
  extraSequence        Int?
  invoice              Invoice?  @relation(fields: [invoiceId], references: [id])
  files                File[]
  templateFor          RecurringTask[]     @relation("TemplateTask")
  shootDetail          ShootDetail?
  SocialPost           SocialPost[]
  user                 User                @relation("AssignedTasks", fields: [assignedTo], references: [id])
  client               Client?             @relation(fields: [clientId], references: [id])
  clientUser           User?               @relation("ClientUserTasks", fields: [clientUserId], references: [id])
  monthlyDeliverable   MonthlyDeliverable? @relation(fields: [monthlyDeliverableId], references: [id])
  oneOffDeliverable    OneOffDeliverable?  @relation(fields: [oneOffDeliverableId], references: [id])
  qcReviewer           User?               @relation("QCReviewedTasks", fields: [qcReviewedBy], references: [id])
  taskFeedback         TaskFeedback[]
  titlingJob           TitlingJob?
  eodReportItems       EditorEodReportItem[]

  @@index([assignedTo])
  @@index([clientId])
  @@index([status])
  @@index([qc_specialist])
  @@index([scheduler])
  @@index([videographer])
  @@index([clientUserId])
  @@index([createdAt])
  @@index([assignedTo, status])
  @@index([clientId, status])
  @@index([dueDate, status])
  @@index([qcReviewedBy])
  @@index([clientId, monthlyDeliverableId, monthFolder])
  @@index([isExtra])
}

model ShootDetail {
  id                String    @id @default(cuid())
  taskId            String    @unique
  location          String?
  shootDate         DateTime?
  referenceLinks    String[]
  referenceFiles    Json?
  camera            String?
  quality           String?
  frameRate         String?
  lighting          String?
  exclusions        String?
  videographerNotes String?
  videographerId    Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  videographer      User?     @relation("VideographerShootDetails", fields: [videographerId], references: [id])
}

model TitlingJob {
  id            String    @id @default(cuid())
  taskId        String    @unique
  status        String    @default("PENDING")
  assemblyId    String?
  error         String?
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?
  videoFileId   String?
  videoFileName String?
  videoDuration Int?
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assemblyId])
  @@index([createdAt])
}

model TaskFeedback {
  id         String    @id @default(cuid())
  taskId     String
  fileId     String?
  folderType String
  feedback   String
  status     String    @default("needs_revision")
  timestamp  String?
  category   String?
  createdBy  Int
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation("TaskFeedbackAuthor", fields: [createdBy], references: [id])
  file       File?     @relation(fields: [fileId], references: [id])
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([fileId])
  @@index([taskId, folderType])
}

model RecurringTask {
  id                  String             @id @default(cuid())
  clientId            String
  deliverableId       String
  templateTaskId      String?
  nextRunDate         DateTime
  lastRunDate         DateTime?
  scheduleType        String
  active              Boolean            @default(true)
  createdAt           DateTime           @default(now())
  defaultAssignedTo   Int?
  defaultQcSpecialist Int?
  defaultScheduler    Int?
  defaultVideographer Int?
  client              Client             @relation(fields: [clientId], references: [id])
  deliverable         MonthlyDeliverable @relation(fields: [deliverableId], references: [id])
  templateTask        Task?              @relation("TemplateTask", fields: [templateTaskId], references: [id])
}

model Client {
  id                      String                   @id @default(cuid())
  userId                  Int?                     @unique
  name                    String
  email                   String
  companyName             String?
  phone                   String
  createdBy               String?
  status                  String                   @default("active")
  accountManagerId        String?
  startDate               DateTime?
  renewalDate             DateTime?
  lastActivity            DateTime?
  requiresClientReview    Boolean                  @default(false)
  requiresVideographer    Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  uploadedFiles           Json?
  brandGuidelines         Json?
  projectSettings         Json?
  billing                 Json?
  postingSchedule         Json?
  currentProgress         Json?
  driveFolderId           String?
  rawFootageFolderId      String?
  essentialsFolderId      String?
  emails                  String[]                 @default([])
  phones                  String[]                 @default([])
  outputsFolderId         String?
  slackChannelName        String?
  slackEnabled            Boolean                  @default(false)
  slackWebhookUrl         String?
  hasPostingServices      Boolean                  @default(true)
  isTrial                 Boolean                  @default(false)
  rawFootageStorageUsed   BigInt?                  @default(0)
  rawFootageStorageLimit  BigInt?                  @default(3298534883328)
  storageAlert90Sent      Boolean?                 @default(false)
  storageAlert95Sent      Boolean?                 @default(false)
  storageLastCalculated   DateTime?                @db.Timestamp(6)
  facebookPages           FacebookPage[]
  stripeCustomer          StripeCustomer?
  brandAssets             BrandAsset[]
  user                    User?                    @relation(fields: [userId], references: [id])
  revenues                ClientRevenue[]
  editorClientPermissions EditorClientPermission[] @relation("EditorClientPerms")
  guidelines              Guideline[]
  jobs                    Job[]
  metaAccount             MetaAccount?
  metaSnapshots           MetaSnapshot[]
  monthlyDeliverables     MonthlyDeliverable[]
  monthlyRuns             MonthlyRun[]
  oneOffDeliverables      OneOffDeliverable[]
  recurringTasks          RecurringTask[]
  SocialAccount           SocialAccount[]
  socialLogins            SocialLogin[]
  tasks                   Task[]
  postedContents          PostedContent[]
  postingTargets          PostingTarget[]
  linkedUsers             User[]                   @relation("LinkedClientUsers")
  youtubeChannel          YouTubeChannel?
  youtubeSnapshots        YouTubeSnapshot[]

  @@index([status])
}

model MonthlyDeliverable {
  id              String          @id @default(cuid())
  clientId        String
  type            String
  quantity        Int
  videosPerDay    Int
  postingSchedule String
  postingDays     String[]
  postingTimes    String[]
  platforms       String[]
  description     String?
  isTrial         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  client          Client          @relation(fields: [clientId], references: [id])
  recurringTasks  RecurringTask[]
  tasks           Task[]
}

model OneOffDeliverable {
  id              String   @id @default(cuid())
  clientId        String
  type            String
  quantity        Int
  videosPerDay    Int
  postingSchedule String
  postingDays     String[]
  postingTimes    String[]
  platforms       String[]
  description     String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  billedAt    DateTime?
  invoiceId   String?
  unitPrice   Int?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  client          Client   @relation(fields: [clientId], references: [id])
  tasks           Task[]
}

model BrandAsset {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  type       String
  fileUrl    String
  fileName   String
  fileSize   String
  uploadedAt DateTime @default(now())
  uploadedBy String
  client     Client   @relation(fields: [clientId], references: [id])
}

model File {
  id                 String         @id @default(cuid())
  taskId             String
  name               String
  url                String
  mimeType           String?
  size               BigInt
  uploadedAt         DateTime       @default(now())
  uploadedBy         Int?
  createdAt          DateTime       @default(now())
  folderType         String?
  isActive           Boolean        @default(true)
  replacedAt         DateTime?
  replacedBy         String?
  revisionNote       String?
  s3Key              String?
  version            Int            @default(1)
  codec              String?
  archivedToNas      Boolean        @default(false)
  nasArchivedAt      DateTime?
  nasPath            String?
  proxyUrl           String?
  optimizationError  String?
  optimizationStatus String         @default("NONE")
  task               Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  feedback           TaskFeedback[]

  @@index([taskId, folderType])
  @@index([taskId, isActive])
}

model Notification {
  id        String   @id @default(cuid())
  userId    Int?
  type      String
  title     String
  body      String?
  payload   Json?
  channel   String[] @default([])
  delivered Boolean  @default(false)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, read])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    Int
  channel   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, channel])
}

model MonthlyRun {
  id       String   @id @default(cuid())
  clientId String
  month    Int
  year     Int
  runAt    DateTime @default(now())
  client   Client   @relation(fields: [clientId], references: [id])
}

model Bonus {
  id         Int      @id @default(autoincrement())
  employeeId Int
  amount     Decimal  @db.Decimal(12, 2)
  addedBy    Int?
  createdAt  DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id])
}

model Leave {
  id           Int         @id @default(autoincrement())
  employeeId   Int
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       LeaveStatus @default(PENDING)
  numberOfDays Int
  approvedBy   Int?
  createdAt    DateTime    @default(now())
  deduction    Deduction?
  employee     User        @relation(fields: [employeeId], references: [id])
}

model Deduction {
  id         Int      @id @default(autoincrement())
  employeeId Int
  amount     Decimal  @db.Decimal(12, 2)
  leaveId    Int?     @unique
  month      DateTime
  createdAt  DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id])
  leave      Leave?   @relation(fields: [leaveId], references: [id])
}

model Payroll {
  id              Int           @id @default(autoincrement())
  employeeId      Int
  periodStart     DateTime
  periodEnd       DateTime
  baseSalary      Decimal       @db.Decimal(12, 2)
  totalBonuses    Decimal       @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal       @default(0) @db.Decimal(12, 2)
  netPay          Decimal       @db.Decimal(12, 2)
  status          PayrollStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  paidAt          DateTime?
  hidden          Boolean       @default(false)
  employee        User          @relation(fields: [employeeId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String?
  entityId  String?
  details   String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entity, entityId])
  @@index([timestamp])
  @@index([userId])
}

model Feedback {
  id        String             @id @default(cuid())
  subject   String
  message   String
  category  String
  priority  String
  status    String             @default("pending")
  senderId  Int
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sender    User               @relation("FeedbackSender", fields: [senderId], references: [id])
  responses FeedbackResponse[]

  @@index([senderId])
  @@index([status])
}

model FeedbackResponse {
  id         String   @id @default(cuid())
  message    String
  feedbackId String
  senderId   Int
  createdAt  DateTime @default(now())
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  sender     User     @relation("FeedbackResponseSender", fields: [senderId], references: [id])

  @@index([feedbackId])
  @@index([senderId])
}

model SocialAccount {
  id            String            @id @default(cuid())
  clientId      String
  platform      String
  platformId    String
  platformName  String
  accessToken   String
  refreshToken  String?
  tokenExpiry   DateTime?
  profileUrl    String?
  profileImage  String?
  followerCount Int               @default(0)
  isActive      Boolean           @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  client        Client            @relation(fields: [clientId], references: [id])
  analytics     SocialAnalytics[]
  posts         SocialPost[]

  @@unique([clientId, platform, platformId])
  @@index([clientId])
  @@index([platform])
}

model SocialPost {
  id              String        @id @default(cuid())
  socialAccountId String
  platformPostId  String
  postType        String
  title           String?
  description     String?
  thumbnailUrl    String?
  postUrl         String
  publishedAt     DateTime
  views           Int           @default(0)
  likes           Int           @default(0)
  comments        Int           @default(0)
  shares          Int           @default(0)
  saves           Int?
  watchTime       Int?
  engagementRate  Float?
  taskId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  task            Task?         @relation(fields: [taskId], references: [id])

  @@unique([socialAccountId, platformPostId])
  @@index([socialAccountId])
  @@index([publishedAt])
}

model SocialAnalytics {
  id              String        @id @default(cuid())
  socialAccountId String
  date            DateTime      @db.Date
  followers       Int           @default(0)
  followersGained Int           @default(0)
  followersLost   Int           @default(0)
  views           Int           @default(0)
  likes           Int           @default(0)
  comments        Int           @default(0)
  shares          Int           @default(0)
  impressions     Int?
  reach           Int?
  engagementRate  Float?
  createdAt       DateTime      @default(now())
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])

  @@unique([socialAccountId, date])
  @@index([socialAccountId, date])
}

model SocialLogin {
  id                  String          @id @default(cuid())
  clientId            String?
  platform            String
  username            String
  encryptedPassword   String
  recoveryEmail       String?
  recoveryPhone       String?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  updatedById         Int
  adminOnly           Boolean         @default(false)
  backupCodesLocation String?
  loginUrl            String?
  passwordChangedAt   DateTime        @default(now())
  auditLogs           LoginAuditLog[]
  client              Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  updatedByUser       User            @relation("LoginUpdatedBy", fields: [updatedById], references: [id])
  allowedRoles        String[]        @default([])
  allowedUserIds      Int[]           @default([]) 

  @@unique([clientId, platform])
  @@index([clientId])
  @@index([platform])
  @@index([adminOnly])
}

model UserSecurityPin {
  id             String    @id @default(cuid())
  userId         Int       @unique
  pinHash        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastVerifiedAt DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserTwoFactorAuth {
  id             String    @id @default(cuid())
  userId         Int       @unique
  totpSecret     String
  isEnabled      Boolean   @default(false)
  backupCodes    String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastVerifiedAt DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginAuditLog {
  id        String       @id @default(cuid())
  action    String
  loginId   String?
  userId    Int
  details   String?
  ipAddress String?
  createdAt DateTime     @default(now())
  login     SocialLogin? @relation(fields: [loginId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@index([loginId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model QCAnalytics {
  id             String   @id @default(cuid())
  qcSpecialistId Int
  avgReviewTime  Decimal  @db.Decimal(10, 2)
  approvalRate   Decimal  @db.Decimal(10, 2)
  firstPassRate  Decimal  @db.Decimal(10, 2)
  totalReviews   Int      @default(0)
  approvedCount  Int      @default(0)
  rejectedCount  Int      @default(0)
  period         String   @default("month")
  startDate      DateTime
  endDate        DateTime
  calculatedAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt
  qcSpecialist   User     @relation(fields: [qcSpecialistId], references: [id])

  @@unique([qcSpecialistId, period, startDate])
  @@index([qcSpecialistId])
  @@index([period])
  @@index([calculatedAt])
}

model QCRejectionReason {
  id              String   @id @default(cuid())
  qcSpecialistId  Int
  reason          String
  caseCount       Int      @default(1)
  taskIds         String[] @default([])
  firstOccurrence DateTime @default(now())
  lastOccurrence  DateTime @updatedAt
  qcSpecialist    User     @relation(fields: [qcSpecialistId], references: [id])

  @@unique([qcSpecialistId, reason])
  @@index([qcSpecialistId])
  @@index([reason])
}

model QCAchievement {
  id              String   @id @default(cuid())
  qcSpecialistId  Int
  achievementType String
  unlockedAt      DateTime @default(now())
  achievementData Json?
  qcSpecialist    User     @relation(fields: [qcSpecialistId], references: [id])

  @@unique([qcSpecialistId, achievementType])
  @@index([qcSpecialistId])
  @@index([achievementType])
}

model QCMonthlyTrend {
  id             String   @id @default(cuid())
  qcSpecialistId Int
  year           Int
  month          Int
  reviewCount    Int      @default(0)
  approvedCount  Int      @default(0)
  rejectedCount  Int      @default(0)
  avgReviewTime  Decimal  @db.Decimal(10, 2)
  approvalRate   Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  qcSpecialist   User     @relation(fields: [qcSpecialistId], references: [id])

  @@unique([qcSpecialistId, year, month])
  @@index([qcSpecialistId])
  @@index([year, month])
}

model QCCategoryMetrics {
  id             String   @id @default(cuid())
  qcSpecialistId Int
  category       String
  reviewCount    Int      @default(0)
  approvedCount  Int      @default(0)
  rejectedCount  Int      @default(0)
  approvalRate   Decimal  @db.Decimal(10, 2)
  avgReviewTime  Decimal  @db.Decimal(10, 2)
  period         String   @default("month")
  startDate      DateTime
  endDate        DateTime
  updatedAt      DateTime @updatedAt
  qcSpecialist   User     @relation(fields: [qcSpecialistId], references: [id])

  @@unique([qcSpecialistId, category, period, startDate])
  @@index([qcSpecialistId])
  @@index([category])
}

model ShareableReview {
  id           String    @id @default(cuid())
  taskId       String
  shareToken   String    @unique
  createdBy    Int
  expiresAt    DateTime?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([shareToken])
  @@index([createdBy])
  @@index([expiresAt])
}

model ShareableFile {
  id           String    @id @default(cuid())
  s3Key        String
  fileName     String
  fileSize     BigInt?
  mimeType     String?
  shareToken   String    @unique
  createdBy    Int
