generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                      @id @default(autoincrement())
  name                    String?
  email                   String
  password                String?
  image                   String?
  role                    Role?
  hourlyRate              Decimal?                 @db.Decimal(10, 2)
  monthlyBaseHours        Int?
  employeeStatus          EmployeeStatus?          @default(ACTIVE)
  joinedAt                DateTime?
  worksOnSaturday         Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  resetOTP                String?
  resetOTPExpiry          DateTime?
  hoursPerWeek            Decimal?                 @default(0) @db.Decimal(5, 2)
  phone                   String?                  @unique
  monthlyRate             Int?
  linkedClientId          String?
  emailNotifications      Boolean                  @default(true)
  slackNotifications      Boolean                  @default(false)
  employeeDocuments       EmployeeDocument[]       @relation("EmployeeDocumentOwner")
  uploadedEmployeeDocs    EmployeeDocument[]       @relation("EmployeeDocumentUploader")
  slackUserId             String?
  accounts                Account[]
  affiliateCommissions    AffiliateCommission[]
  commissionAdjustments   CommissionAdjustment[]
  commissionPayouts       CommissionPayout[]
  payoutProfile           SalesRepPayoutProfile?
  auditLogs               AuditLog[]
  bids                    Bid[]
  bonuses                 Bonus[]
  client                  Client?
  ClientPortalAccess      ClientPortalAccess[]
  createdContracts        Contract[]               @relation("ContractCreator")
  deductions              Deduction[]
  editorClientPermissions EditorClientPermission[] @relation("EditorPermissions")
  eodReports              EditorEodReport[]
  feedbackSent            Feedback[]               @relation("FeedbackSender")
  feedbackResponses       FeedbackResponse[]       @relation("FeedbackResponseSender")
  invoicesCreated         Invoice[]                @relation("InvoiceCreator")
  assignedJobs            Job[]                    @relation("JobAssignee")
  createdJobs             Job[]                    @relation("JobCreator")
  leaves                  Leave[]
  loginAuditLogs          LoginAuditLog[]
  payrolls                Payroll[]
  PreClient               PreClient[]
  helpVideos              HelpVideo[]
  achievements            QCAchievement[]
  qcAnalytics             QCAnalytics[]
  categoryMetrics         QCCategoryMetrics[]
  monthlyTrends           QCMonthlyTrend[]
  rejectionReasons        QCRejectionReason[]
  salesActivityLogs       SalesActivityLog[]
  salesLeads              SalesLead[]
  salesLeadGenerationJobs SalesLeadGenerationJob[]
  salesManagerPermissions SalesManagerPermission[] @relation("SalesManagerPermissions")
  salesRepPermissions     SalesManagerPermission[] @relation("SalesRepPermissions")
  schedulerActivityEvents SchedulerActivityEvent[]
  schedulerActivityDailySummaries SchedulerActivityDailySummary[]
  sessions                Session[]
  NasMirrorJob            NasMirrorJob[]
  shootDetails            ShootDetail[]            @relation("VideographerShootDetails")
  updatedSocialLogins     SocialLogin[]            @relation("LoginUpdatedBy")
  assignedTasks           Task[]                   @relation("AssignedTasks")
  clientTasks             Task[]                   @relation("ClientUserTasks")
  qcReviewedTasks         Task[]                   @relation("QCReviewedTasks")
  taskFeedback            TaskFeedback[]           @relation("TaskFeedbackAuthor")
  linkedClient            Client?                  @relation("LinkedClientUsers", fields: [linkedClientId], references: [id])
  securityPin             UserSecurityPin?
  twoFactorAuth           UserTwoFactorAuth?
  folderStatusUpdates     FolderStatus[]
  hiringCandidatesAdded   HiringCandidate[]
  hiringTestTasksReviewed HiringTestTask[]
  convertedFromCandidate  HiringCandidate?         @relation("ConvertedCandidateUser")

  @@index([email])
  @@index([role])
  @@index([employeeStatus])
  @@index([linkedClientId])
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String  @default("pending")
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Task {
  id                   String                @id @default(cuid())
  title                String?
  description          String
  taskType             String?
  status               TaskStatus?           @default(PENDING)
  dueDate              DateTime?
  clientUserId         Int?
  folderType           String?
  assignedTo           Int
  qc_specialist        Int?
  scheduler            Int?
  videographer         Int?
  createdBy            Int?
  clientId             String?
  monthlyDeliverableId String?
  driveFolderId        String?
  attachments          Json?
  driveLinks           String[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  priority             String?
  taskCategory         String?
  nextDestination      String?
  clientReview         Boolean?              @default(false)
  requiresClientReview Boolean?              @default(false)
  workflowStep         String?
  feedback             String?
  qcNotes              String?
  qcResult             String?
  route                String?
  monthFolder          String?
  outputFolderId       String?
  deliverableType      String?
  textContent          String?
  tags                 Tag[]
  hasCovers            Boolean               @default(false)
  hasMainFile          Boolean               @default(false)
  hasMusicLicense      Boolean               @default(false)
  hasThumbnails        Boolean               @default(false)
  hasTiles             Boolean               @default(false)
  socialMediaLinks     Json                  @default("[]")
  platform             String?
  suggestedTitles      Json?
  titlingError         String?
  titlingStatus        String                @default("NONE")
  transcript           String?
  transcriptSummary    String?
  qcReviewedAt         DateTime?
  qcReviewedBy         Int?
  oneOffDeliverableId  String?
  recurringMonth       String?
  billedAt             DateTime?
  invoiceId            String?
  isTrial              Boolean               @default(false)
  extraSequence        Int?
  isExtra              Boolean               @default(false)
  relatedTaskId        String?
  titleSetByQC         Boolean               @default(false)
  postingTitle         String?
  isSponsored          Boolean               @default(false)
  titleSetByClient     Boolean               @default(false)
  postingDescriptions  Json?
  postingTags          Json?
  postingTitles        Json?
  eodReportItems       EditorEodReportItem[]
  files                File[]
  templateFor          RecurringTask[]       @relation("TemplateTask")
  shootDetail          ShootDetail?
  SocialPost           SocialPost[]
  user                 User                  @relation("AssignedTasks", fields: [assignedTo], references: [id])
  client               Client?               @relation(fields: [clientId], references: [id])
  clientUser           User?                 @relation("ClientUserTasks", fields: [clientUserId], references: [id])
  invoice              Invoice?              @relation(fields: [invoiceId], references: [id])
  monthlyDeliverable   MonthlyDeliverable?   @relation(fields: [monthlyDeliverableId], references: [id])
  oneOffDeliverable    OneOffDeliverable?    @relation(fields: [oneOffDeliverableId], references: [id])
  qcReviewer           User?                 @relation("QCReviewedTasks", fields: [qcReviewedBy], references: [id])
  relatedTask          Task?                 @relation("RelatedTasks", fields: [relatedTaskId], references: [id])
  relatedTasks         Task[]                @relation("RelatedTasks")
  taskFeedback         TaskFeedback[]
  titlingJob           TitlingJob?

  @@index([assignedTo])
  @@index([clientId])
  @@index([status])
  @@index([monthFolder])
  @@index([qc_specialist])
  @@index([scheduler])
  @@index([videographer])
  @@index([clientUserId])
  @@index([createdAt])
  @@index([assignedTo, status])
  @@index([clientId, status])
  @@index([dueDate, status])
  @@index([qcReviewedBy])
  @@index([clientId, monthlyDeliverableId, monthFolder])
  @@index([isExtra])
}

model ShootDetail {
  id                String    @id @default(cuid())
  taskId            String    @unique
  location          String?
  shootDate         DateTime?
  referenceLinks    String[]
  referenceFiles    Json?
  camera            String?
  quality           String?
  frameRate         String?
  lighting          String?
  exclusions        String?
  videographerNotes String?
  videographerId    Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  videographer      User?     @relation("VideographerShootDetails", fields: [videographerId], references: [id])
}

model TitlingJob {
  id            String    @id @default(cuid())
  taskId        String    @unique
  status        String    @default("PENDING")
  assemblyId    String?
  error         String?
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?
  videoFileId   String?
  videoFileName String?
  videoDuration Int?
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assemblyId])
  @@index([createdAt])
}

model TaskFeedback {
  id             String    @id @default(cuid())
  taskId         String
  fileId         String?
  folderType     String
  feedback       String
  status         String    @default("needs_revision")
  timestamp      String?
  category       String?
  createdBy      Int
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy Int?
  user           User      @relation("TaskFeedbackAuthor", fields: [createdBy], references: [id])
  file           File?     @relation(fields: [fileId], references: [id])
  task           Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([fileId])
  @@index([taskId, folderType])
}

model RecurringTask {
  id                  String             @id @default(cuid())
  clientId            String
  deliverableId       String
  templateTaskId      String?
  nextRunDate         DateTime
  lastRunDate         DateTime?
  scheduleType        String
  active              Boolean            @default(true)
  createdAt           DateTime           @default(now())
  defaultAssignedTo   Int?
  defaultQcSpecialist Int?
  defaultScheduler    Int?
  defaultVideographer Int?
  client              Client             @relation(fields: [clientId], references: [id])
  deliverable         MonthlyDeliverable @relation(fields: [deliverableId], references: [id])
  templateTask        Task?              @relation("TemplateTask", fields: [templateTaskId], references: [id])
}

model Client {
  id                           String                    @id @default(cuid())
  userId                       Int?                      @unique
  name                         String
  email                        String
  companyName                  String?
  phone                        String
  address                      String?
  createdBy                    String?
  status                       String                    @default("active")
  accountManagerId             String?
  startDate                    DateTime?
  renewalDate                  DateTime?
  lastActivity                 DateTime?
  requiresClientReview         Boolean                   @default(false)
  requiresVideographer         Boolean                   @default(false)
  requiresCoverImage           Boolean                   @default(false)
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  uploadedFiles                Json?
  brandGuidelines              Json?
  projectSettings              Json?
  billing                      Json?
  postingSchedule              Json?
  currentProgress              Json?
  driveFolderId                String?
  rawFootageFolderId           String?
  essentialsFolderId           String?
  emails                       String[]                  @default([])
  phones                       String[]                  @default([])
  outputsFolderId              String?
  slackChannelName             String?
  slackEnabled                 Boolean                   @default(false)
  slackWebhookUrl              String?
  hasPostingServices           Boolean                   @default(true)
  rawFootageStorageUsed        BigInt?                   @default(0)
  rawFootageStorageLimit       BigInt?                   @default(3298534883328)
  storageAlert90Sent           Boolean?                  @default(false)
  storageAlert95Sent           Boolean?                  @default(false)
  storageLastCalculated        DateTime?                 @db.Timestamp(6)
  isTrial                      Boolean                   @default(false)
  clientReviewDeliverableTypes String[]                  @default([])
  rawFootageLinks              Json                      @default("[]")
  portalPasswordSet            Boolean                   @default(false)
  preClientId                  String?                   @unique
  welcomeVideoWatched          Boolean                   @default(false)
  templateHashtags             String[]                  @default([])
  brandAssets                  BrandAsset[]
  user                         User?                     @relation(fields: [userId], references: [id])
  portalAccess                 ClientPortalAccess?
  meetingNotes                 MeetingNote[]
  revenues                     ClientRevenue[]
  editorClientPermissions      EditorClientPermission[]  @relation("EditorClientPerms")
  facebookPages                FacebookPage[]
  guidelines                   Guideline[]
  jobs                         Job[]
  metaAccount                  MetaAccount?
  metaSnapshots                MetaSnapshot[]
  monthlyDeliverables          MonthlyDeliverable[]
  monthlyRuns                  MonthlyRun[]
  OnboardingToken              OnboardingToken?
  oneOffDeliverables           OneOffDeliverable[]
  postedContents                PostedContent[]
  postingTargets               PostingTarget[]
  recurringTasks               RecurringTask[]
  SocialAccount                SocialAccount[]
  socialLogins                 SocialLogin[]
  stripeCustomer                StripeCustomer?
  tasks                        Task[]
  linkedUsers                  User[]                    @relation("LinkedClientUsers")
  youtubeChannel                YouTubeChannel?
  youtubeSnapshots              YouTubeSnapshot[]
  folderStatuses                FolderStatus[]

  @@index([status])
}

model MonthlyDeliverable {
  id              String          @id @default(cuid())
  clientId        String
  type            String
  quantity        Int
  videosPerDay    Int
  postingSchedule String
  postingDays     String[]
  postingTimes    String[]
  platforms       String[]
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  isTrial         Boolean         @default(false)
  client          Client          @relation(fields: [clientId], references: [id])
  recurringTasks  RecurringTask[]
  tasks           Task[]
}

model OneOffDeliverable {
  id              String    @id @default(cuid())
  clientId        String
  type            String
  quantity        Int
  videosPerDay    Int
  postingSchedule String
  postingDays     String[]
  postingTimes    String[]
  platforms       String[]
  description     String?
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  billedAt        DateTime?
  invoiceId       String?
  unitPrice       Int?
  client          Client    @relation(fields: [clientId], references: [id])
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  tasks           Task[]
}

model BrandAsset {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  type       String
  fileUrl    String
  fileName   String
  fileSize   String
  uploadedAt DateTime @default(now())
  uploadedBy String
  client     Client   @relation(fields: [clientId], references: [id])
}

model File {
  id                 String         @id @default(cuid())
  taskId             String
  name               String
  url                String
  mimeType           String?
  size               BigInt
  uploadedAt         DateTime       @default(now())
  uploadedBy         Int?
  createdAt          DateTime       @default(now())
  folderType         String?
  isActive           Boolean        @default(true)
  replacedAt         DateTime?
  replacedBy         String?
  revisionNote       String?
  s3Key              String?
  version            Int            @default(1)
  codec              String?
  archivedToNas      Boolean        @default(false)
  nasArchivedAt      DateTime?
  nasPath            String?
  deletedFromCloud   Boolean        @default(false)
  deletedFromCloudAt DateTime?
  proxyUrl           String?
  optimizationError  String?
  optimizationStatus String         @default("NONE")
  reviewDriveUrl     String?
  youtubeVideoId     String?
  youtubeUploadedAt  DateTime?
  task               Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  feedback           TaskFeedback[]

  @@index([taskId, folderType])
  @@index([taskId, isActive])
}

model Notification {
  id        String   @id @default(cuid())
  userId    Int?
  type      String
  title     String
  body      String?
  payload   Json?
  channel   String[] @default([])
  delivered Boolean  @default(false)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, read])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    Int
  channel   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, channel])
}

model MonthlyRun {
  id       String   @id @default(cuid())
  clientId String
  month    Int
  year     Int
  runAt    DateTime @default(now())
  client   Client   @relation(fields: [clientId], references: [id])
}

model Bonus {
  id         Int      @id @default(autoincrement())
  employeeId Int
  amount     Decimal  @db.Decimal(12, 2)
  addedBy    Int?
  createdAt  DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id])
}

model Leave {
  id           Int         @id @default(autoincrement())
  employeeId   Int
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       LeaveStatus @default(PENDING)
  numberOfDays Int
  approvedBy   Int?
  createdAt    DateTime    @default(now())
  deduction    Deduction?
  employee     User        @relation(fields: [employeeId], references: [id])
}

model Deduction {
  id         Int      @id @default(autoincrement())
  employeeId Int
  amount     Decimal  @db.Decimal(12, 2)
  leaveId    Int?     @unique
  month      DateTime
  createdAt  DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id])
  leave      Leave?   @relation(fields: [leaveId], references: [id])
}

model Payroll {
  id              Int           @id @default(autoincrement())
  employeeId      Int
  periodStart     DateTime
  periodEnd       DateTime
  baseSalary      Decimal       @db.Decimal(12, 2)
  totalBonuses    Decimal       @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal       @default(0) @db.Decimal(12, 2)
  netPay          Decimal       @db.Decimal(12, 2)
  status          PayrollStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  paidAt          DateTime?
  hidden          Boolean       @default(false)
  employee        User          @relation(fields: [employeeId], references: [id])
}

model FolderStatus {
  id          String   @id @default(cuid())
  clientId    String
  s3KeyPrefix String
  status      String
  updatedById Int?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@unique([clientId, s3KeyPrefix])
  @@index([clientId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String?
  entityId  String?
  details   String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entity, entityId])
  @@index([timestamp])
  @@index([userId])
}

// Raw interaction events — clicks, page opens, idle transitions — captured
// client-side for scheduler-role users only. Pruned after 30 days by the
// nightly rollup job; SchedulerActivityDailySummary is what survives long
// term for reporting.
model SchedulerActivityEvent {
  id          String   @id @default(cuid())
  userId      Int
  sessionId   String
  eventType   String   // click | navigation | idle_start | idle_end | session_start | session_end | visibility_hidden | visibility_visible
  path        String?
  targetLabel String?
  targetTag   String?
  metadata    Json?
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([eventType])
}

// One row per scheduler per calendar day. Built by the nightly rollup job
// from SchedulerActivityEvent before the raw rows for that day get pruned.
// This is what the admin dashboard actually queries — never the raw table
// directly, so it stays fast no matter how much raw data has accumulated.
model SchedulerActivityDailySummary {
  id            String    @id @default(cuid())
  userId        Int
  date          DateTime  // normalized to midnight UTC — one row per user per day
  activeMinutes Int       @default(0)
  idleMinutes   Int       @default(0)
  clickCount    Int       @default(0)
  sessionCount  Int       @default(0)
  firstEventAt  DateTime?
  lastEventAt   DateTime?
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

// Tracks daily YouTube Data API quota consumption (default budget: 10,000
// units/day, an upload costs ~1600). One row per calendar day (Pacific
// time — that's when YouTube's quota actually resets). Checked before every
// upload attempt so we can fall back to Drive mirroring proactively instead
// of waiting for a quotaExceeded error.
model YoutubeQuotaUsage {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD, Pacific time
  unitsUsed Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Feedback {
  id        String             @id @default(cuid())
  subject   String
  message   String
  category  String
  priority  String
  status    String             @default("pending")
  senderId  Int
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sender    User               @relation("FeedbackSender", fields: [senderId], references: [id])
  responses FeedbackResponse[]

  @@index([senderId])
  @@index([status])
}

model FeedbackResponse {
  id         String   @id @default(cuid())
  message    String
  feedbackId String
  senderId   Int
  createdAt  DateTime @default(now())
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  sender     User     @relation("FeedbackResponseSender", fields: [senderId], references: [id])

  @@index([feedbackId])
  @@index([senderId])
}

model SocialAccount {
  id            String            @id @default(cuid())
  clientId      String
  platform      String
  platformId    String
  platformName  String
  accessToken   String
  refreshToken  String?
  tokenExpiry   DateTime?
  profileUrl    String?
  profileImage  String?
  followerCount Int               @default(0)
  isActive      Boolean           @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  client        Client            @relation(fields: [clientId], references: [id])
  analytics     SocialAnalytics[]
  posts         SocialPost[]

  @@unique([clientId, platform, platformId])
  @@index([clientId])
  @@index([platform])
}

model SocialPost {
  id              String        @id @default(cuid())
  socialAccountId String
  platformPostId  String
  postType        String
  title           String?
  description     String?
  thumbnailUrl    String?
  postUrl         String
  publishedAt     DateTime
  views           Int           @default(0)
  likes           Int           @default(0)
  comments        Int           @default(0)
  shares          Int           @default(0)
  saves           Int?
  watchTime       Int?
  engagementRate  Float?
  taskId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  task            Task?         @relation(fields: [taskId], references: [id])

  @@unique([socialAccountId, platformPostId])
  @@index([socialAccountId])
  @@index([publishedAt])
}

model SocialAnalytics {
  id              String        @id @default(cuid())
  socialAccountId String
  date            DateTime      @db.Date
  followers       Int           @default(0)
  followersGained Int           @default(0)
  followersLost   Int           @default(0)
  views           Int           @default(0)
  likes           Int           @default(0)
  comments        Int           @default(0)
  shares          Int           @default(0)
  impressions     Int?
  reach           Int?
  engagementRate  Float?
  createdAt       DateTime      @default(now())
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])

  @@unique([socialAccountId, date])
  @@index([socialAccountId, date])
}

model SocialLogin {
  id                  String          @id @default(cuid())
  clientId            String?
  platform            String
  username            String
  encryptedPassword   String
  recoveryEmail       String?
  recoveryPhone       String?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  updatedById         Int
  adminOnly           Boolean         @default(false)
  backupCodesLocation String?
  loginUrl            String?
  passwordChangedAt   DateTime        @default(now())
  allowedRoles        String[]        @default([])
  allowedUserIds      Int[]           @default([])
  accessRole          String?         // For platforms added via email-invite (Facebook, YouTube) — e.g. "Editor", "Admin", "Advertiser" — instead of a shared password
  auditLogs           LoginAuditLog[]
  client              Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  updatedByUser       User            @relation("LoginUpdatedBy", fields: [updatedById], references: [id])

  @@unique([clientId, platform])
  @@index([clientId])
  @@index([platform])
  @@index([adminOnly])
}

model UserSecurityPin {
  id             String    @id @default(cuid())
  userId         Int       @unique
  pinHash        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastVerifiedAt DateTime?
