  clientId        String
  title           String?
  platform        String
  url             String
  postedAt        DateTime
  deliverableType String?
  taskId          String?  // Optional reference to original task (for tracking)
  createdAt       DateTime @default(now())
  
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@index([clientId])
  @@index([postedAt])
  @@index([platform])
}

// Per-client, per-platform posting targets for daily tracking
model PostingTarget {
  id              String   @id @default(cuid())
  clientId        String
  platform        String   // e.g. "IG (Trials)", "FB Profile", "FB Page", "TT", "YT", "Snapchat", "LI"
  deliverableType String   // e.g. "SF", "BSF", "SQF", "LF", "SEP", "HP"
  count           Int      // how many per period (e.g. 4 SF/day)
  frequency       String   @default("daily") // "daily", "weekly", "sunday"
  extras          Json?    // { tiles: true, thumb: true, note: "every sunday" }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, platform, deliverableType])
  @@index([clientId])
}

model EditorEodReport {
  id           String                @id @default(cuid())
  editorId     Int
  reportDate   String
  slackChannel String?
  slackTs      String?
  status       String                @default("DRAFT")
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  editor       User                  @relation(fields: [editorId], references: [id])
  items        EditorEodReportItem[]

  @@unique([editorId, reportDate])
  @@index([editorId])
  @@index([reportDate])
}

model EditorEodReportItem {
  id           String           @id @default(cuid())
  reportId     String
  taskId       String
  taskTitle    String
  proofLinks   Json             @default("[]")
  statusAtSend String?
  createdAt    DateTime         @default(now())
  report       EditorEodReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task         Task             @relation(fields: [taskId], references: [id])

  @@unique([reportId, taskId])
  @@index([reportId])
  @@index([taskId])
}
