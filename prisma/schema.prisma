  sublabel  String?
  iconKey   String?
  order     Int                    @default(0)
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  steps     PortfolioJourneyStep[]
}

model PortfolioJourneyStep {
  id        String                 @id @default(cuid())
  clientId  String
  imageUrl  String
  caption   String
  order     Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  client    PortfolioJourneyClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Contract {
  id                   String             @id @default(cuid())
  title                String
  description          String?
  status               ContractStatus     @default(DRAFT)
  s3Key                String
  signedS3Key          String?
  fileName             String
  fileSize             BigInt
  createdById          Int
  clientId             String?
  templateId           String?
  expiresAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  message              String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  annotations          Json?
  allowVariableSigners Boolean            @default(false)
  preClientId          String?
  signwellDocumentId   String?
  signwellRequestId    String?
  requiresSignature    Boolean            @default(true)
  createdBy            User               @relation("ContractCreator", fields: [createdById], references: [id])
  template             ContractTemplate?  @relation(fields: [templateId], references: [id])
  auditLogs            ContractAuditLog[]
  signers              ContractSigner[]

  @@index([status])
  @@index([createdById])
  @@index([clientId])
  @@index([createdAt])
}

model ContractTemplate {
  id          String     @id @default(cuid())
  name        String
  description String?
  s3Key       String
  fileName    String
  fileSize    BigInt
  createdById Int
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contracts   Contract[]

  @@index([isActive])
  @@index([createdById])
}

model ContractSigner {
  id               String       @id @default(cuid())
  contractId       String
  name             String
  email            String
  role             String       @default("signer")
  status           SignerStatus @default(PENDING)
  signToken        String       @unique
  signedAt         DateTime?
  viewedAt         DateTime?
  declinedAt       DateTime?
  declineReason    String?
  signatureS3Key   String?
  signatureType    String?
  order            Int          @default(0)
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  isVariableSigner Boolean      @default(false)
  smsVerified      Boolean      @default(false)
  contract         Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([signToken])
  @@index([email])
  @@index([status])
}

model ContractAuditLog {
  id          String   @id @default(cuid())
  contractId  String
  action      String
  performedBy String?
  ipAddress   String?
  userAgent   String?
  details     String?
  createdAt   DateTime @default(now())
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([action])
  @@index([createdAt])
}

model EmployeeDocument {
  id           String   @id @default(cuid())
  employeeId   Int
  title        String
  s3Key        String
  fileName     String
  fileSize     Int
  uploadedById Int
  createdAt    DateTime @default(now())

  employee   User @relation("EmployeeDocumentOwner", fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("EmployeeDocumentUploader", fields: [uploadedById], references: [id])

  @@index([employeeId])
}

model StripeCustomer {
  id                   String          @id @default(cuid())
  clientId             String          @unique
  stripeCustomerId     String          @unique
  defaultPaymentMethod String?
  currency             String          @default("usd")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  invoices             Invoice[]
  paymentMethods       PaymentMethod[]
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscriptions        Subscription[]

  @@index([stripeCustomerId])
}

model PaymentMethod {
  id                    String         @id @default(cuid())
  stripeCustomerId      String
  stripePaymentMethodId String         @unique
  type                  String
  isDefault             Boolean        @default(false)
  cardBrand             String?
  cardLast4             String?
  cardExpMonth          Int?
  cardExpYear           Int?
  bankName              String?
  bankLast4             String?
  bankAccountType       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  stripeCustomer        StripeCustomer @relation(fields: [stripeCustomerId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model Subscription {
  id                   String             @id @default(cuid())
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  amount               Int
  currency             String             @default("usd")
  interval             String             @default("month")
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stripeCustomer       StripeCustomer     @relation(fields: [stripeCustomerId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model Invoice {
  id                     String              @id @default(cuid())
  stripeCustomerId       String
  stripeInvoiceId        String?             @unique
  invoiceNumber          String              @unique
  status                 InvoiceStatus       @default(DRAFT)
  amount                 Int
  amountPaid             Int                 @default(0)
  currency               String              @default("usd")
  dueDate                DateTime?
  paidAt                 DateTime?
  description            String?
  lineItems              Json
  notes                  String?
  isRecurring            Boolean             @default(false)
  subscriptionId         String?
  stripePaymentIntentId  String?
  stripeHostedInvoiceUrl String?
  stripePdfUrl           String?
  metadata               Json?
  createdBy              Int?
  sentAt                 DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  creator                User?               @relation("InvoiceCreator", fields: [createdBy], references: [id])
  stripeCustomer         StripeCustomer      @relation(fields: [stripeCustomerId], references: [id], onDelete: Cascade)
  oneOffDeliverables     OneOffDeliverable[]
  payments               Payment[]
  billedTasks            Task[]

  @@index([stripeCustomerId])
  @@index([status])
  @@index([dueDate])
  @@index([invoiceNumber])
}

model Payment {
  id                    String        @id @default(cuid())
  invoiceId             String
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  amount                Int
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  paymentMethod         String?
  failureReason         String?
  receiptUrl            String?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  invoice               Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([stripePaymentIntentId])
  @@index([status])
}

model BillingPlan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  stripePriceId   String   @unique
  stripeProductId String
  amount          Int
  currency        String   @default("usd")
  interval        String   @default("month")
  isActive        Boolean  @default(true)
  features        Json?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

model leads {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(200)
  niche            String?   @db.VarChar(100)
  status           String    @default("new") @db.VarChar(20)
  notes            String?
  contactedAt      DateTime?
  createdAt        DateTime  @default(now())
  detectedNeed     String?   @db.VarChar(300)
  matchedService   String?   @db.VarChar(200)
  postText         String?
  postUrl          String?   @db.VarChar(500)
  profileUrl       String    @db.VarChar(500)
  suggestedMessage String?

  @@index([createdAt])
  @@index([profileUrl])
  @@index([status])
}

model PostedContent {
  id              String   @id @default(cuid())
  clientId        String
  title           String?
  platform        String
  url             String
  postedAt        DateTime
  deliverableType String?
  taskId          String?
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([postedAt])
  @@index([platform])
  @@index([clientId, postedAt])
}

model PostingTarget {
  id              String   @id @default(cuid())
  clientId        String
  platform        String
  deliverableType String
  count           Int
  frequency       String   @default("daily")
  extras          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, platform, deliverableType])
  @@index([clientId])
}

model EditorEodReport {
  id           String                @id @default(cuid())
  editorId     Int
  reportDate   String
  slackChannel String?
  slackTs      String?
  status       String                @default("DRAFT")
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  editor       User                  @relation(fields: [editorId], references: [id])
  items        EditorEodReportItem[]

  @@unique([editorId, reportDate])
  @@index([editorId])
  @@index([reportDate])
}

model EditorEodReportItem {
  id           String          @id @default(cuid())
  reportId     String
  taskId       String
  taskTitle    String
  proofLinks   Json            @default("[]")
  statusAtSend String?
  createdAt    DateTime        @default(now())
  report       EditorEodReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task         Task            @relation(fields: [taskId], references: [id])

  @@unique([reportId, taskId])
  @@index([reportId])
  @@index([taskId])
}

model NasSyncLog {
  id           String   @id @default(cuid())
  status       String
  completedAt  DateTime
  bucketName   String?
  paths        Json     @default("[]")
  filesCount   Int?
  bytesCount   BigInt?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([completedAt])
  @@index([status])
}

model ClientPortalAccess {
  id                String             @id @default(cuid())
  clientId          String             @unique
  status            PortalAccessStatus @default(ONBOARDING)
  billingAnchorDate DateTime?
  nextBillingDate   DateTime?
  arrearsPolicy     String             @default("current_only")
  adminUnlockedById Int?
  adminUnlockedAt   DateTime?
  lockedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  User              User?              @relation(fields: [adminUnlockedById], references: [id])
  Client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([nextBillingDate])
  @@index([status])
}

model OnboardingToken {
  id        String    @id @default(cuid())
  clientId  String    @unique
  token     String    @unique @default(cuid())
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

enum HiringCandidateStatus {
  NEW
  CONTACTED
  TEST_SENT
  TEST_SUBMITTED
  IN_REVIEW
  HIRED
  REJECTED
}

enum HiringTestTaskStatus {
  PENDING
  SENT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

model MeetingNote {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  driveDocId  String
  driveDocUrl String
  title       String
  meetingDate DateTime
  status      String    @default("draft") // draft | sent
  sentAt      DateTime?
  sentBy      String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
}

// Editor hiring pipeline: candidate DB -> emailed test task (token link,
// no login required) -> candidate submits (pasted link or direct upload) ->
// admin reviews in QC-style approve/reject flow.
model HiringCandidate {
  id           String                @id @default(cuid())
  name         String
  email        String
  phone        String?
  portfolioUrl String?
  resumeUrl    String?
  source       String?
  notes        String?
  status       HiringCandidateStatus @default(NEW)
  createdById  Int?
  createdBy    User?                 @relation(fields: [createdById], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  testTasks    HiringTestTask[]

  convertedUserId Int?      @unique
  convertedUser   User?     @relation("ConvertedCandidateUser", fields: [convertedUserId], references: [id])
  convertedAt     DateTime?

  @@index([status])
  @@index([email])
}

model HiringTestTask {
  id              String               @id @default(cuid())
  candidateId     String
  candidate       HiringCandidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  title           String
  instructions    String
  rawFootageUrl   String?
  submissionToken String               @unique @default(cuid())
  status          HiringTestTaskStatus @default(PENDING)
  submissionUrl   String?
  submissionS3Key String?
  sentAt          DateTime?
  submittedAt     DateTime?
  reviewedById    Int?
  reviewedBy      User?                @relation(fields: [reviewedById], references: [id])
  reviewNotes     String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([candidateId])
  @@index([status])
}

model PreClient {
  id          String          @id @default(cuid())
  name        String
  email       String
  phone       String?
  companyName String?
  address     String?
  status      PreClientStatus @default(QUALIFIED)
  createdById Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User            @relation(fields: [createdById], references: [id])
  quotes      Quote[]

  @@index([createdById])
  @@index([status])
}

model Quote {
  id              String      @id @default(cuid())
  preClientId     String
  version         Int         @default(1)
  status          QuoteStatus @default(DRAFT)
  services        Json
  totalAmount     Int
  notes           String?
  validDays       Int         @default(30)
  shareToken      String      @unique @default(cuid())
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  changeRequest   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  acceptanceText  String?
  inclusions      Json        @default("[]")
  preparedBy      String?
  terms           Json        @default("[]")
  preClient       PreClient   @relation(fields: [preClientId], references: [id], onDelete: Cascade)

  @@index([preClientId])
  @@index([shareToken])
  @@index([status])
}

model NasMirrorJob {
  id            String   @id @default(cuid())
  clientName    String
  monthFolder   String
  status        String   @default("pending") // pending | running | completed | failed
  scannedCount  Int      @default(0)
  copiedCount   Int      @default(0)
  verifiedCount Int      @default(0)
  deletedCount  Int      @default(0)
  failedCount   Int      @default(0)
  folderType    String   @default("outputs") // 'outputs' | 'raw-footage'
  folderPath    String?  // full relative path under clientName for raw-footage jobs, e.g. "June-2025/SF12"
  currentFile   String?
  errorMessage  String?
  triggeredById Int?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  TriggeredBy   User?    @relation(fields: [triggeredById], references: [id])

  @@index([status])
  @@index([clientName, monthFolder])
  @@index([createdAt])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  PAUSED
}

enum InvoiceStatus {
